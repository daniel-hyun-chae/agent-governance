# Dev container docker-compose template for governance-compatible projects.
# Copy this to project/docker-compose.devcontainer.yml and customize.
#
# Key governance requirements (do not remove):
#   - Volume mount: ..:/workspaces/workspace:cached (mounts governance root)
#   - OPENCODE_CONFIG_DIR: points to governance .opencode/ inside container
#   - OPENCODE_CONFIG: points to governance opencode.json inside container

services:
  dev:
    build:
      context: .
      dockerfile: .devcontainer/Dockerfile
    volumes:
      # Mount governance root (parent of project/) so OpenCode can access
      # governance agents, rules, skills, and config.
      - ..:/workspaces/workspace:cached
      # Uncomment if using a named volume for node_modules:
      # - dev_node_modules:/workspaces/workspace/project/node_modules
    environment:
      # --- Governance integration (required) ---
      OPENCODE_CONFIG_DIR: /workspaces/workspace/.opencode
      OPENCODE_CONFIG: /workspaces/workspace/opencode.json
      # --- Project-specific (customize below) ---
      # DATABASE_URL: postgresql://postgres:postgres@host.docker.internal:5432/postgres
    ports: []
    # Keep container running for VS Code to attach
    command: sleep infinity
    # Uncomment for Docker-in-Docker support:
    # privileged: true

# Uncomment if using named volumes:
# volumes:
#   dev_node_modules:
