# Dev container Dockerfile template for governance-compatible projects.
# Copy this to project/.devcontainer/Dockerfile and customize.
#
# Choose a base image appropriate for your project's runtime.
# Examples:
#   mcr.microsoft.com/devcontainers/javascript-node:20
#   mcr.microsoft.com/devcontainers/python:3.12
#   mcr.microsoft.com/devcontainers/go:1.22
#   mcr.microsoft.com/devcontainers/java:21
#   mcr.microsoft.com/devcontainers/base:bullseye

ARG BASE_IMAGE=mcr.microsoft.com/devcontainers/base:bullseye
FROM ${BASE_IMAGE}

# --- Corporate proxy CA certificate (remove block if not needed) ---
# If your network uses a corporate proxy with a custom root CA,
# uncomment and replace the certificate filename below.
#
# COPY my-root-ca.crt /usr/share/ca-certificates/my-root-ca.crt
# RUN echo "my-root-ca.crt" >> /etc/ca-certificates.conf \
#     && update-ca-certificates
# ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
# ENV REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# --- Project runtime tools (customize below) ---
# Examples:
#   RUN corepack enable && corepack prepare pnpm@latest --activate
#   RUN pip install --no-cache-dir poetry
#   RUN go install golang.org/x/tools/gopls@latest

# --- OpenCode CLI (required -- do not remove) --------------------------------
# Layer 1 of 2: bake OpenCode into the image so it is available immediately on
# container start. The postCreateCommand install script (Layer 2) provides a
# belt-and-suspenders fallback in case the image is stale or the install fails
# during build.
ARG REMOTE_USER=node
RUN curl -fsSL https://opencode.ai/install -o /tmp/install_opencode.sh \
    && chmod +x /tmp/install_opencode.sh \
    && OPENCODE_INSTALL_DIR=/usr/local/bin /tmp/install_opencode.sh \
    && rm -f /tmp/install_opencode.sh \
    && if [ ! -x /usr/local/bin/opencode ]; then \
         if [ -x /root/.opencode/bin/opencode ]; then \
           ln -sf /root/.opencode/bin/opencode /usr/local/bin/opencode; \
         else \
           echo "ERROR: opencode binary not found after install" && exit 1; \
         fi; \
       fi \
    && /usr/local/bin/opencode --version

# Prepare runtime directories used by OpenCode and common tools.
RUN mkdir -p /home/${REMOTE_USER}/.cache \
             /home/${REMOTE_USER}/.cache/ms-playwright \
             /home/${REMOTE_USER}/.local/share/opencode \
             /home/${REMOTE_USER}/.local/state/opencode \
             /home/${REMOTE_USER}/.local/share/uv/tools \
    && chown -R ${REMOTE_USER}:${REMOTE_USER} /home/${REMOTE_USER}/.cache /home/${REMOTE_USER}/.local
# --- End OpenCode CLI ---------------------------------------------------------

# --- Workspace setup ---
# The workspace path must match docker-compose volume mount + devcontainer.json workspaceFolder.
ARG WORKSPACE_DIR=/workspaces/workspace/project
RUN mkdir -p ${WORKSPACE_DIR} \
    && chown -R ${REMOTE_USER}:${REMOTE_USER} /workspaces
WORKDIR ${WORKSPACE_DIR}
