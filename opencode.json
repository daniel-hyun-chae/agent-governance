{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/*.md",
    "project/.opencode-overrides/rules/*.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/sse"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app/sse"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--headless"]
    },
    "code-index": {
      "type": "local",
      "command": ["uvx", "code-index-mcp"]
    }
  }
}
